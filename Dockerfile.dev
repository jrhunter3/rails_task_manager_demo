# syntax=docker/dockerfile:1
# Development image — includes all gems (dev/test), mounts code as a volume.

ARG RUBY_VERSION=3.4.6
FROM docker.io/library/ruby:$RUBY_VERSION-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential git libjemalloc2 libpq-dev libvips \
      libyaml-dev pkg-config postgresql-client curl && \
    rm -rf /var/lib/apt/lists /var/cache/apt/archives

ENV LD_PRELOAD="/usr/lib/$(uname -m)-linux-gnu/libjemalloc.so.2" \
    BUNDLE_PATH="/bundle"

WORKDIR /rails

COPY Gemfile Gemfile.lock ./
RUN bundle install

EXPOSE 3000
CMD ["./bin/rails", "server", "-b", "0.0.0.0"]
