# Required — copy the key from config/master.key
RAILS_MASTER_KEY=

# Required — choose a PostgreSQL password
RAILS_TASK_MANAGER_DEMO_DATABASE_PASSWORD=

# Required for deployment — the public hostname (no protocol)
APP_HOST=example.com

# Set to false for local Docker without SSL; keep true behind a real reverse proxy
# FORCE_SSL=true

# Optional
PORT=80
DEV_PORT=3000
RAILS_LOG_LEVEL=info
RAILS_MAX_THREADS=3
SENTRY_DSN=
REDIS_URL=redis://redis:6379/0
MAILER_FROM=noreply@taskmanager.demo
MAILER_SENDER=noreply@taskmanager.demo
