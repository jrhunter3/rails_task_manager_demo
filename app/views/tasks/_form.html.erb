<%= form_with model: [@project, @task] do |f| %>
  <%= render "application/error_messages", form: f %>

  <div>
    <%= f.label :title %>
    <%= f.text_field :title, required: true %>
  </div>

  <div>
    <%= f.label :description %>
    <%= f.text_area :description %>
  </div>

  <div>
    <%= f.label :priority %>
    <%= f.select :priority, Task.priorities.keys.map { |p| [p.humanize, p] } %>
  </div>

  <div>
    <%= f.label :due_date %>
    <%= f.date_field :due_date %>
  </div>

  <div>
    <%= f.label :files %>
    <%= f.file_field :files, multiple: true %>
  </div>

  <div>
    <%= f.submit @task.new_record? ? t(".create") : t(".update") %>
  </div>
<% end %>
