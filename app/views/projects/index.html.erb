<div class="toolbar">
  <h1><%= t(".title") %></h1>
  <%= link_to t(".new"), new_project_path %>
</div>

<%= search_form_for @q do |f| %>
  <%= f.search_field :name_or_description_cont, placeholder: t(".search_placeholder") %>
  <%= f.submit t(".search") %>
<% end %>

<% if @projects.any? %>
  <ul>
    <% @projects.each do |project| %>
      <li>
        <%= link_to project.name, project %>
        <small>(<%= project.owner.email %>)</small>
      </li>
    <% end %>
  </ul>

  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% else %>
  <p><%= t(".empty") %></p>
<% end %>
